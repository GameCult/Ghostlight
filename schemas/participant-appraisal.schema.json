{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GameCult/Ghostlight/schemas/participant-appraisal.schema.json",
  "title": "Ghostlight Participant Appraisal",
  "description": "Participant-local interpretation of an observable event from current character state, known facts, pressures, perceived relationships, and visibility.",
  "type": "object",
  "required": [
    "schema_version",
    "appraisal_id",
    "review_status",
    "scene_loop_id",
    "turn_id",
    "participant_agent_id",
    "event_ref",
    "current_character_state_ref",
    "participant_local_context",
    "observable_event_summary",
    "known_facts",
    "active_pressures",
    "perceived_relationships",
    "interpretation",
    "emotional_appraisal",
    "interpretation_label",
    "confidence_notes",
    "candidate_implications",
    "review"
  ],
  "properties": {
    "schema_version": { "const": "ghostlight.participant_appraisal.v0" },
    "appraisal_id": { "type": "string", "minLength": 1 },
    "review_status": { "type": "string" },
    "scene_loop_id": { "type": "string", "minLength": 1 },
    "turn_id": { "type": "string", "minLength": 1 },
    "participant_agent_id": { "type": "string", "minLength": 1 },
    "event_ref": { "type": "string", "minLength": 1 },
    "current_character_state_ref": { "type": "string", "minLength": 1 },
    "participant_local_context": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "observable_event_summary": { "type": "string", "minLength": 1 },
    "known_facts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "active_pressures": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "perceived_relationships": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "interpretation": { "type": "string", "minLength": 1 },
    "emotional_appraisal": { "type": "string", "minLength": 1 },
    "interpretation_label": { "enum": ["misread", "correct_read", "ambiguous", "strategic_read", "unknown"] },
    "confidence_notes": { "type": "string", "minLength": 1 },
    "candidate_implications": { "type": "object" },
    "review": { "type": "object" }
  }
}
