{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GameCult/Ghostlight/schemas/reviewed-mutation.schema.json",
  "title": "Ghostlight Reviewed Mutation",
  "description": "Reviewed state mutation receipt separating accepted, rejected, and deferred deltas after event appraisal.",
  "type": "object",
  "required": [
    "schema_version",
    "mutation_id",
    "review_status",
    "scene_loop_id",
    "turn_id",
    "prior_state_refs",
    "event_ref",
    "responder_output_ref",
    "appraisal_refs",
    "accepted_deltas",
    "rejected_deltas",
    "deferred_deltas",
    "authority_notes",
    "post_state_summary",
    "review"
  ],
  "properties": {
    "schema_version": { "const": "ghostlight.reviewed_mutation.v0" },
    "mutation_id": { "type": "string", "minLength": 1 },
    "review_status": { "type": "string" },
    "scene_loop_id": { "type": "string", "minLength": 1 },
    "turn_id": { "type": "string", "minLength": 1 },
    "prior_state_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "event_ref": { "type": "string", "minLength": 1 },
    "responder_output_ref": { "type": "string", "minLength": 1 },
    "appraisal_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "accepted_deltas": { "type": "array", "minItems": 1 },
    "rejected_deltas": { "type": "array" },
    "deferred_deltas": { "type": "array" },
    "authority_notes": { "type": "string", "minLength": 1 },
    "post_state_summary": { "type": "string", "minLength": 1 },
    "review": { "type": "object" }
  }
}
